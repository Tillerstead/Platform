# Tillerstead Toolkit — Environment Template
# Copy to .env and fill in real values. NEVER commit .env with real credentials.

# ── Database ─────────────────────────────────────────────────
# Local development
DATABASE_URL=postgresql://user:password@localhost:5432/tillerstead_toolkit
# Railway deployment: use the DATABASE_URL provided in Railway dashboard

# ── Application ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
ALLOWED_ORIGINS=http://localhost:3000,https://tillerstead.com,https://www.tillerstead.com
DEBUG=false

# ── Redis (job queue) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Railway Redis: redis://default:password@host:port

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── File storage ─────────────────────────────────────────────
# Railway uses ephemeral filesystem — set these to /app/uploads etc. in production
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# ── Optional: External API keys ──────────────────────────────
HOMEDEPOT_FEED_PATH=
THIRDPARTY_API_KEY=
THIRDPARTY_API_URL=

